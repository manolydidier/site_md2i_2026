generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique @db.VarChar(255)
  username      String?    @unique @db.VarChar(100)
  passwordHash  String
  firstName     String?    @db.VarChar(100)
  lastName      String?    @db.VarChar(100)
  phone         String?    @db.VarChar(30)
  avatarUrl     String?
  status        UserStatus @default(PENDING)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  createdAudits AuditLog[]  @relation("AuditActor")
  authTokens    AuthToken[]
  pages         Page[]
  posts         Post[]
  products      Product[]
  projects      Project[]
  sessions      Session[]
  assignedRoles UserRole[]  @relation("UserRoleAssignedBy")
  userRoles     UserRole[]

  // Email Marketing
  contactGroups ContactGroup[]
  contacts      Contact[]
  campaigns     Campaign[]

  // Email Automations
  emailAutomations      EmailAutomation[]
  emailAutomationRuns   EmailAutomationRun[]
  emailAutomationEmails EmailAutomationEmail[]

  // CRM
  crmCompanies               CrmCompany[]
  crmOffers                  CrmOffer[]
  crmOpportunities           CrmOpportunity[]
  crmTenders                 CrmTender[]
  crmTasks                   CrmTask[]
  crmActivities              CrmActivity[]
  crmStatusOptions           CrmStatusOption[]
  crmOpportunityStageOptions CrmOpportunityStageOption[]
  crmMarketingCampaigns      CrmMarketingCampaign[]
  crmPublications            CrmPublication[]
  crmTrackedLinks            CrmTrackedLink[]
  crmPublicationLogs         CrmPublicationLog[]

  @@index([email])
  @@index([username])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  code            String           @unique @db.VarChar(100)
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
  @@index([code])
  @@index([isSystem])
  @@map("roles")
}

model PermissionResource {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  code            String           @unique @db.VarChar(100)
  description     String?
  category        String?          @db.VarChar(100)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([name])
  @@index([code])
  @@index([isActive])
  @@index([category])
  @@map("permission_resources")
}

model RolePermission {
  id                String            @id @default(uuid()) @db.Uuid
  roleId            String            @db.Uuid
  resourceId        String            @db.Uuid
  canRead           Boolean           @default(false)
  canCreate         Boolean           @default(false)
  canUpdate         Boolean           @default(false)
  canDelete         Boolean           @default(false)
  canList           Boolean           @default(false)
  canExport         Boolean           @default(false)
  canApprove        Boolean           @default(false)
  canManage         Boolean           @default(false)
  canImport         Boolean           @default(false)
  canPrint          Boolean           @default(false)
  canValidate       Boolean           @default(false)
  canCancel         Boolean           @default(false)
  canArchive        Boolean           @default(false)
  canRestore        Boolean           @default(false)
  canDownload       Boolean           @default(false)
  canUpload         Boolean           @default(false)
  canExecute        Boolean           @default(false)
  specialPermission SpecialPermission @default(NONE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  resource PermissionResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role     Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceId])
  @@index([roleId])
  @@index([resourceId])
  @@index([specialPermission])
  @@map("role_permissions")
}

model UserRole {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  roleId       String   @db.Uuid
  assignedById String?  @db.Uuid
  assignedAt   DateTime @default(now())

  assignedBy User? @relation("UserRoleAssignedBy", fields: [assignedById], references: [id])
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  token        String    @unique
  refreshToken String?   @unique
  ipAddress    String?   @db.VarChar(64)
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model SiteSetting {
  id               String   @id @default("default")
  contactEmail     String?
  contactPhone     String?
  contactPhoneHref String?
  address          String?
  websiteUrl       String?
  linkedinUrl      String?
  facebookUrl      String?
  xUrl             String?
  maintenanceMode  Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@map("site_settings")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @db.VarChar(100)
  metadata  Json?
  ipAddress String?  @db.VarChar(64)
  userAgent String?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Page {
  id            String     @id @default(uuid()) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  description   String?
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?    @db.Text
  status        PageStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String     @db.Uuid
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@map("pages")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts Post[]

  @@index([slug])
  @@map("categories")
}

model Post {
  id            String     @id @default(uuid()) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  excerpt       String?
  coverImage    String?
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String     @db.Uuid
  categoryId    String?    @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?      @db.JsonB
  gjsHtml       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  gjsJs         String?

  tags     PostTag[]
  author   User      @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
  @@map("posts")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  posts PostTag[]

  @@index([slug])
  @@map("tags")
}

model PostTag {
  postId String @db.Uuid
  tagId  String @db.Uuid

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Project {
  id            String        @id @default(uuid()) @db.Uuid
  title         String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  excerpt       String?
  coverImage    String?
  images        String[]
  techStack     String[]
  projectUrl    String?
  githubUrl     String?
  status        ProjectStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String        @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("projects")
}

model ProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@map("product_categories")
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  excerpt       String?
  price         Decimal?      @db.Decimal(10, 2)
  coverImage    String?
  images        String[]
  status        ProductStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String        @db.Uuid
  categoryId    String?       @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author   User             @relation(fields: [authorId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id])

  crmOffers        CrmOffer[]
  crmOpportunities CrmOpportunity[]

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@map("products")
}

model ContactMessage {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(255)
  phone     String?       @db.VarChar(30)
  subject   String?       @db.VarChar(255)
  message   String
  status    ContactStatus @default(NEW)
  ipAddress String?       @db.VarChar(64)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

model Reference {
  id            String          @id @default(uuid()) @db.Uuid
  country       String          @db.VarChar(100)
  code          String          @db.VarChar(10)
  lat           Decimal         @db.Decimal(10, 6)
  lng           Decimal         @db.Decimal(10, 6)
  title         String          @db.VarChar(500)
  slug          String          @unique @db.VarChar(500)
  excerpt       String          @db.Text
  image         String          @db.VarChar(500)
  details       String          @db.Text
  date          String          @db.VarChar(10)
  client        String          @db.VarChar(200)
  category      String          @db.VarChar(100)
  tags          String[]
  impact        String?         @db.VarChar(200)
  technologies  String[]
  team          String?         @db.VarChar(100)
  duration      String?         @db.VarChar(50)
  budget        String?         @db.VarChar(50)
  status        ReferenceStatus @default(PUBLISHED)
  publishedAt   DateTime?
  authorId      String?         @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([country])
  @@index([category])
  @@index([date])
  @@index([client])
  @@index([status])
  @@index([slug])
  @@map("references")
}

// ============================================================
// EMAIL MARKETING
// ============================================================

model ContactGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts       Contact[]
  members        ContactGroupMember[]
  campaigns      Campaign[]
  campaignGroups CampaignGroup[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
  @@index([userId, name])
  @@map("contact_groups")
}

model ContactGroupMember {
  id        String   @id @default(cuid())
  contactId String
  groupId   String
  createdAt DateTime @default(now())

  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group   ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([contactId, groupId])
  @@index([contactId])
  @@index([groupId])
  @@index([groupId, contactId])
  @@map("contact_group_members")
}

model Contact {
  id           String   @id @default(cuid())
  email        String
  firstName    String?
  lastName     String?
  phone        String?
  metadata     Json?
  isActive     Boolean  @default(true)
  unsubscribed Boolean  @default(false)
  groupId      String?
  userId       String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // CRM - informations contact
  jobTitle      String?
  companyName   String?
  country       String?
  city          String?
  notes         String?   @db.Text
  consentDate   DateTime?
  consentSource String?

  // CRM - ancien statut enum, conservé temporairement pour compatibilité
  crmStatus CrmContactStatus @default(NEW)

  // CRM - statut dynamique
  crmStatusOptionId String?
  crmStatusOption   CrmStatusOption? @relation(fields: [crmStatusOptionId], references: [id], onDelete: SetNull)

  // CRM - source encore en enum pour le moment
  crmSource CrmLeadSource @default(MANUAL)

  crmCompanyId String?
  crmCompany   CrmCompany? @relation(fields: [crmCompanyId], references: [id], onDelete: SetNull)

  crmOpportunities CrmOpportunity[]
  crmTasks         CrmTask[]
  crmActivities    CrmActivity[]

  // Email Automations
  emailAutomationRuns   EmailAutomationRun[]
  emailAutomationEmails EmailAutomationEmail[]

  // Email Marketing
  group            ContactGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupMemberships ContactGroupMember[]
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients       CampaignRecipient[]

  @@unique([email, userId])
  @@index([userId], map: "contacts_user_id_idx")
  @@index([groupId], map: "contacts_group_id_idx")
  @@index([crmCompanyId], map: "contacts_crm_company_id_idx")
  @@index([crmStatus], map: "contacts_crm_status_idx")
  @@index([crmStatusOptionId], map: "contacts_crm_status_option_id_idx")
  @@index([crmSource], map: "contacts_crm_source_idx")
  @@index([createdAt], map: "contacts_created_at_idx")
  @@index([isActive], map: "contacts_is_active_idx")
  @@index([unsubscribed], map: "contacts_unsubscribed_idx")
  @@index([userId, createdAt], map: "contacts_user_created_idx")
  @@index([userId, groupId], map: "contacts_user_group_idx")
  @@index([userId, crmStatus], map: "contacts_user_crm_status_idx")
  @@index([userId, crmStatusOptionId], map: "contacts_user_status_option_idx")
  @@index([userId, crmSource], map: "contacts_user_crm_source_idx")
  @@index([userId, crmStatus, crmSource], map: "contacts_user_status_source_idx")
  @@index([userId, crmStatusOptionId, crmSource], map: "contacts_user_dyn_status_source_idx")
  @@index([userId, groupId, crmStatus], map: "contacts_user_group_status_idx")
  @@index([userId, groupId, crmStatusOptionId], map: "contacts_user_group_dyn_status_idx")
  @@index([userId, groupId, crmSource], map: "contacts_user_group_source_idx")
  @@index([userId, groupId, crmStatus, crmSource], map: "contacts_user_group_status_source_idx")
  @@index([userId, groupId, crmStatusOptionId, crmSource], map: "contacts_user_group_dyn_status_source_idx")
  @@index([userId, isActive], map: "contacts_user_active_idx")
  @@index([userId, unsubscribed], map: "contacts_user_unsubscribed_idx")
  @@index([userId, isActive, unsubscribed], map: "contacts_user_active_unsubscribed_idx")
  @@index([userId, crmStatus, createdAt], map: "contacts_user_status_created_idx")
  @@index([userId, crmStatusOptionId, createdAt], map: "contacts_user_dyn_status_created_idx")
  @@index([userId, groupId, createdAt], map: "contacts_user_group_created_idx")
  @@index([userId, groupId, crmStatus, crmSource, createdAt], map: "contacts_user_group_status_source_created_idx")
  @@index([userId, groupId, crmStatusOptionId, crmSource, createdAt], map: "contacts_user_group_dyn_status_source_created_idx")
  @@map("contacts")
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  subject         String
  htmlContent     String         @db.Text
  fromName        String         @default("Mon App")
  fromEmail       String
  replyTo         String?
  groupId         String?
  status          CampaignStatus @default(DRAFT)
  userId          String         @db.Uuid
  sentAt          DateTime?
  scheduledAt     DateTime?
  totalRecipients Int            @default(0)
  sentCount       Int            @default(0)
  failedCount     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  group          ContactGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients     CampaignRecipient[]
  logs           EmailLog[]
  campaignGroups CampaignGroup[]

  // Email Automations
  automationSteps EmailAutomationStep[]

  // CRM Marketing
  crmMarketingCampaigns CrmMarketingCampaign[]

  @@index([userId])
  @@index([status])
  @@index([groupId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, scheduledAt])
  @@map("campaigns")
}

model CampaignGroup {
  id         String   @id @default(cuid())
  campaignId String
  groupId    String
  createdAt  DateTime @default(now())

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  group    ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([campaignId, groupId])
  @@index([campaignId])
  @@index([groupId])
  @@index([groupId, campaignId])
  @@map("campaign_groups")
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  contactId  String
  email      String
  sent       Boolean   @default(false)
  delivered  Boolean   @default(false)
  openedAt   DateTime?
  clickedAt  DateTime?
  error      String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@index([campaignId, sent])
  @@index([campaignId, delivered])
  @@index([campaignId, openedAt])
  @@index([campaignId, clickedAt])
  @@index([contactId, createdAt])
  @@map("campaign_recipients")
}

model EmailLog {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  status     String
  message    String?
  provider   String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
  @@index([campaignId, createdAt])
  @@index([email])
  @@index([status])
  @@map("email_logs")
}

// ============================================================
// EMAIL AUTOMATIONS
// ============================================================

model EmailAutomation {
  id          String  @id @default(cuid())
  name        String
  description String?

  trigger EmailAutomationTrigger @default(CONTACT_CREATED)

  triggerEvent       EmailAutomationTriggerEvent      @default(CONTACT_CREATED)
  conditionField     EmailAutomationConditionField    @default(NONE)
  conditionOperator  EmailAutomationConditionOperator @default(ALWAYS)
  conditionValue     String?
  conditionValueJson Json?

  isActive Boolean @default(true)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  steps EmailAutomationStep[]
  runs  EmailAutomationRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([trigger])
  @@index([triggerEvent])
  @@index([conditionField])
  @@index([conditionOperator])
  @@index([conditionValue])
  @@index([isActive])
  @@index([createdAt])
  @@index([userId, trigger])
  @@index([userId, isActive])
  @@index([userId, trigger, isActive])
  @@index([userId, isActive, createdAt])
  @@index([userId, triggerEvent], map: "idx_email_auto_user_event")
  @@index([userId, triggerEvent, isActive], map: "idx_email_auto_user_event_active")
  @@index([userId, triggerEvent, conditionField], map: "idx_email_auto_user_event_field")
  @@index([userId, triggerEvent, conditionField, conditionOperator], map: "idx_email_auto_user_event_field_op")
  @@index([userId, triggerEvent, isActive, conditionField], map: "idx_email_auto_user_event_active_field")
  @@index([userId, triggerEvent, isActive, conditionField, conditionOperator], map: "idx_email_auto_user_event_active_field_op")
  @@index([userId, isActive, triggerEvent, createdAt], map: "idx_email_auto_user_active_event_created")
  @@map("email_automations")
}

model EmailAutomationStep {
  id           String @id @default(cuid())
  automationId String

  automation EmailAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  position   Int
  delayValue Int       @default(0)
  delayUnit  DelayUnit @default(HOURS)

  subject  String
  content  String  @db.Text
  isActive Boolean @default(true)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  emails EmailAutomationEmail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([automationId, position])
  @@index([automationId])
  @@index([automationId, position])
  @@index([automationId, isActive])
  @@index([campaignId])
  @@map("email_automation_steps")
}

model EmailAutomationRun {
  id String @id @default(cuid())

  automationId String
  automation   EmailAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trigger EmailAutomationTrigger @default(CONTACT_CREATED)

  triggerEvent EmailAutomationTriggerEvent @default(CONTACT_CREATED)

  conditionSnapshot Json?

  status EmailAutomationRunStatus @default(ACTIVE)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?

  emails EmailAutomationEmail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([automationId])
  @@index([status])
  @@index([trigger])
  @@index([triggerEvent])
  @@index([startedAt])
  @@index([userId, contactId, status])
  @@index([userId, automationId, status])
  @@index([userId, trigger, status])
  @@index([userId, triggerEvent, status])
  @@index([userId, startedAt])
  @@index([contactId, automationId, status])
  @@index([automationId, status])
  @@index([contactId, status])
  @@index([userId, status, startedAt])
  @@index([userId, triggerEvent, status, startedAt])
  @@map("email_automation_runs")
}

model EmailAutomationEmail {
  id String @id @default(cuid())

  runId String
  run   EmailAutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  stepId String
  step   EmailAutomationStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject String
  content String @db.Text

  status EmailAutomationEmailStatus @default(PENDING)

  scheduledAt DateTime
  sentAt      DateTime?
  failedAt    DateTime?
  error       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([runId])
  @@index([stepId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([status, scheduledAt])
  @@index([userId, status, scheduledAt])
  @@index([runId, status])
  @@index([contactId, status])
  @@index([userId, contactId, status])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([contactId, scheduledAt])
  @@index([runId, scheduledAt])
  @@index([stepId, status])
  @@map("email_automation_emails")
}

// ============================================================
// CRM MULTI-PRODUITS — MD2I
// ============================================================

model CrmCompany {
  id      String         @id @default(cuid())
  name    String
  type    CrmCompanyType @default(COMPANY)
  sector  String?
  website String?
  email   String?
  phone   String?
  country String?
  city    String?
  address String?
  notes   String?        @db.Text

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contacts      Contact[]
  opportunities CrmOpportunity[]
  tenders       CrmTender[]
  tasks         CrmTask[]
  activities    CrmActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([name])
  @@index([type])
  @@index([country])
  @@index([userId, type])
  @@index([userId, country])
  @@index([userId, createdAt])
  @@map("crm_companies")
}

model CrmOffer {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  status      CrmOfferStatus @default(DRAFT)

  normalPrice Decimal? @db.Decimal(12, 2)
  promoPrice  Decimal? @db.Decimal(12, 2)
  currency    String?  @default("EUR") @db.VarChar(10)

  startsAt DateTime?
  endsAt   DateTime?

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunities CrmOpportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@index([userId, status])
  @@index([userId, startsAt])
  @@index([userId, endsAt])
  @@map("crm_offers")
}

model CrmOpportunity {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text

  amount      Decimal? @db.Decimal(12, 2)
  currency    String?  @default("EUR") @db.VarChar(10)
  probability Int      @default(0)

  stage  String        @default("NEW") @db.VarChar(50)
  source CrmLeadSource @default(MANUAL)

  requestType    CrmRequestType @default(CONTACT)
  nextFollowUpAt DateTime?
  lostReason     String?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  offerId String?
  offer   CrmOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  tenderId String?
  tender   CrmTender? @relation(fields: [tenderId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks      CrmTask[]
  activities CrmActivity[]

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  landingPage String?
  referrer    String?

  crmMarketingCampaignId String?
  crmMarketingCampaign   CrmMarketingCampaign? @relation(fields: [crmMarketingCampaignId], references: [id], onDelete: SetNull)

  crmPublicationId String?
  crmPublication   CrmPublication? @relation(fields: [crmPublicationId], references: [id], onDelete: SetNull)

  crmTrackedLinkId String?
  crmTrackedLink   CrmTrackedLink? @relation(fields: [crmTrackedLinkId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([productId])
  @@index([offerId])
  @@index([tenderId])
  @@index([stage])
  @@index([source])
  @@index([requestType])
  @@index([createdAt])
  @@index([nextFollowUpAt])
  @@index([crmMarketingCampaignId])
  @@index([crmPublicationId])
  @@index([crmTrackedLinkId])
  @@index([userId, stage])
  @@index([userId, source])
  @@index([userId, requestType])
  @@index([userId, stage, source])
  @@index([userId, createdAt])
  @@index([userId, nextFollowUpAt])
  @@index([userId, crmMarketingCampaignId])
  @@index([userId, crmPublicationId])
  @@index([userId, crmTrackedLinkId])
  @@index([userId, utmSource])
  @@index([userId, utmCampaign])
  @@index([userId, utmSource, createdAt])
  @@index([userId, utmCampaign, createdAt])
  @@index([contactId, stage])
  @@index([companyId, stage])
  @@map("crm_opportunities")
}

model CrmTender {
  id          String  @id @default(cuid())
  title       String
  reference   String?
  buyerName   String?
  country     String?
  sourceUrl   String?
  description String? @db.Text
  notes       String? @db.Text

  status CrmTenderStatus @default(IDENTIFIED)

  publishedAt     DateTime?
  deadline        DateTime?
  estimatedAmount Decimal?  @db.Decimal(12, 2)
  currency        String?   @default("EUR") @db.VarChar(10)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunities CrmOpportunity[]
  tasks         CrmTask[]
  activities    CrmActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([deadline])
  @@index([country])
  @@index([userId, status])
  @@index([userId, deadline])
  @@index([userId, country])
  @@map("crm_tenders")
}

model CrmTask {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text

  status   CrmTaskStatus   @default(TODO)
  priority CrmTaskPriority @default(MEDIUM)

  dueDate        DateTime?
  completedAt    DateTime?
  reminderSentAt DateTime?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  tenderId String?
  tender   CrmTender? @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([tenderId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([userId, dueDate])
  @@index([userId, status, priority])
  @@index([contactId, status])
  @@index([companyId, status])
  @@index([opportunityId, status])
  @@map("crm_tasks")
}

model CrmActivity {
  id          String          @id @default(cuid())
  type        CrmActivityType
  title       String
  description String?         @db.Text
  metadata    Json?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  tenderId String?
  tender   CrmTender? @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([tenderId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type])
  @@index([userId, createdAt])
  @@index([contactId, createdAt])
  @@index([companyId, createdAt])
  @@index([opportunityId, createdAt])
  @@map("crm_activities")
}

// ============================================================
// CRM MARKETING AUTOMATION
// ============================================================

model CrmMarketingCampaign {
  id        String                     @id @default(cuid())
  name      String
  objective String?                    @db.Text
  audience  String?
  status    CrmMarketingCampaignStatus @default(DRAFT)

  budget   Decimal? @db.Decimal(12, 2)
  currency String?  @default("EUR") @db.VarChar(10)

  startsAt DateTime?
  endsAt   DateTime?

  emailCampaignId String?
  emailCampaign   Campaign? @relation(fields: [emailCampaignId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  publications  CrmPublication[]
  trackedLinks  CrmTrackedLink[]
  opportunities CrmOpportunity[]
  logs          CrmPublicationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([emailCampaignId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("crm_marketing_campaigns")
}

model CrmPublication {
  id        String                @id @default(cuid())
  channel   CrmPublicationChannel
  title     String
  content   String                @db.Text
  ctaLabel  String?
  targetUrl String?

  status         CrmPublicationStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  providerPostId String?
  providerUrl    String?
  failureReason  String?              @db.Text
  notes          String?              @db.Text

  // Retry / anti double-publication
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?
  lockedAt      DateTime?
  lockToken     String?

  campaignId String
  campaign   CrmMarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  trackedLinkId String?
  trackedLink   CrmTrackedLink? @relation(fields: [trackedLinkId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunities CrmOpportunity[]
  logs          CrmPublicationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([campaignId])
  @@index([trackedLinkId])
  @@index([channel])
  @@index([status])
  @@index([scheduledAt])
  @@index([publishedAt])
  @@index([retryCount])
  @@index([nextRetryAt])
  @@index([lockedAt])
  @@index([lockToken])
  @@index([userId, status])
  @@index([userId, channel])
  @@index([userId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([status, nextRetryAt])
  @@index([userId, status, scheduledAt])
  @@map("crm_publications")
}

model CrmTrackedLink {
  id             String    @id @default(cuid())
  slug           String    @unique
  label          String
  destinationUrl String
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  clickCount     Int       @default(0)
  lastClickedAt  DateTime?

  campaignId String?
  campaign   CrmMarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  publications  CrmPublication[]
  clicks        CrmTrackedLinkClick[]
  opportunities CrmOpportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([userId])
  @@index([campaignId])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
  @@index([utmContent])
  @@index([userId, createdAt])
  @@map("crm_tracked_links")
}

model CrmTrackedLinkClick {
  id        String   @id @default(cuid())
  linkId    String
  referrer  String?
  userAgent String?
  ipAddress String?  @db.VarChar(64)
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())

  link CrmTrackedLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([createdAt])
  @@index([isBot])
  @@index([ipAddress])
  @@index([linkId, createdAt])
  @@index([linkId, isBot])
  @@map("crm_tracked_link_clicks")
}

model CrmPublicationLog {
  id String @id @default(cuid())

  publicationId String?
  publication   CrmPublication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)

  campaignId String?
  campaign   CrmMarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel CrmPublicationChannel?

  action  String
  status  String
  message String?
  error   String? @db.Text

  attempt          Int   @default(1)
  requestPayload   Json?
  providerResponse Json?
  metadata         Json?

  createdAt DateTime @default(now())

  @@index([publicationId])
  @@index([campaignId])
  @@index([userId])
  @@index([channel])
  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@index([publicationId, createdAt])
  @@index([campaignId, createdAt])
  @@index([userId, createdAt])
  @@map("crm_publication_logs")
}

