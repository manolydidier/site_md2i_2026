generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(uuid()) @db.Uuid
  email         String      @unique @db.VarChar(255)
  username      String?     @unique @db.VarChar(100)
  passwordHash  String
  firstName     String?     @db.VarChar(100)
  lastName      String?     @db.VarChar(100)
  phone         String?     @db.VarChar(30)
  avatarUrl     String?
  status        UserStatus  @default(PENDING)
  emailVerified Boolean     @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  createdAudits AuditLog[]  @relation("AuditActor")
  authTokens    AuthToken[]
  pages         Page[]
  posts         Post[]
  products      Product[]
  projects      Project[]
  sessions      Session[]
  assignedRoles UserRole[]  @relation("UserRoleAssignedBy")
  userRoles     UserRole[]

  @@index([email])
  @@index([username])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  code            String           @unique @db.VarChar(100)
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
  @@index([code])
  @@index([isSystem])
  @@map("roles")
}

model PermissionResource {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  code            String           @unique @db.VarChar(100)
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([name])
  @@index([code])
  @@index([isActive])
  @@map("permission_resources")
}

model RolePermission {
  id                String             @id @default(uuid()) @db.Uuid
  roleId            String             @db.Uuid
  resourceId        String             @db.Uuid
  canRead           Boolean            @default(false)
  canCreate         Boolean            @default(false)
  canUpdate         Boolean            @default(false)
  canDelete         Boolean            @default(false)
  canList           Boolean            @default(false)
  canExport         Boolean            @default(false)
  canApprove        Boolean            @default(false)
  canManage         Boolean            @default(false)
  specialPermission SpecialPermission  @default(NONE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  resource          PermissionResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role              Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceId])
  @@index([roleId])
  @@index([resourceId])
  @@index([specialPermission])
  @@map("role_permissions")
}

model UserRole {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  roleId       String   @db.Uuid
  assignedById String?  @db.Uuid
  assignedAt   DateTime @default(now())
  assignedBy   User?    @relation("UserRoleAssignedBy", fields: [assignedById], references: [id])
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  token        String    @unique
  refreshToken String?   @unique
  ipAddress    String?   @db.VarChar(64)
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @db.VarChar(100)
  metadata  Json?
  ipAddress String?  @db.VarChar(64)
  userAgent String?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Page {
  id            String     @id @default(uuid()) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  description   String?
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  status        PageStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String     @db.Uuid
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  author        User       @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@map("pages")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@index([slug])
  @@map("categories")
}

model Post {
  id            String     @id @default(uuid()) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  excerpt       String?
  coverImage    String?
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String     @db.Uuid
  categoryId    String?    @db.Uuid
  gjsComponents Json?
  gjsStyles     Json? @db.JsonB
  gjsHtml       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  gjsJs         String?
  tags          PostTag[]
  author        User       @relation(fields: [authorId], references: [id])
  category      Category?  @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
  @@map("posts")
}

model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now())
  posts     PostTag[]

  @@index([slug])
  @@map("tags")
}

model PostTag {
  postId String @db.Uuid
  tagId  String @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Project {
  id            String        @id @default(uuid()) @db.Uuid
  title         String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  excerpt       String?
  coverImage    String?
  images        String[]
  techStack     String[]
  projectUrl    String?
  githubUrl     String?
  status        ProjectStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String        @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  author        User          @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("projects")
}

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([slug])
  @@map("product_categories")
}

model Product {
  id            String           @id @default(uuid()) @db.Uuid
  name          String           @db.VarChar(255)
  slug          String           @unique @db.VarChar(255)
  excerpt       String?
  price         Decimal?         @db.Decimal(10, 2)
  coverImage    String?
  images        String[]
  status        ProductStatus    @default(DRAFT)
  publishedAt   DateTime?
  authorId      String           @db.Uuid
  categoryId    String?          @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs String? @db.Text 
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  author        User             @relation(fields: [authorId], references: [id])
  category      ProductCategory? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@map("products")
}

model ContactMessage {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(255)
  phone     String?       @db.VarChar(30)
  subject   String?       @db.VarChar(255)
  message   String
  status    ContactStatus @default(NEW)
  ipAddress String?       @db.VarChar(64)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  REFRESH_TOKEN
}

enum SpecialPermission {
  NONE
  FULL_ACCESS
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// Modèle Reference autonome (sans lien avec User et Tag existants)
model Reference {
  id            String          @id @default(uuid()) @db.Uuid
  country       String          @db.VarChar(100)
  code          String          @db.VarChar(10)
  lat           Decimal         @db.Decimal(10, 6)
  lng           Decimal         @db.Decimal(10, 6)
  title         String          @db.VarChar(500)
  slug          String          @unique @db.VarChar(500)
  excerpt       String          @db.Text
  image         String          @db.VarChar(500)
  details       String          @db.Text
  date          String          @db.VarChar(10)
  client        String          @db.VarChar(200)
  category      String          @db.VarChar(100)
  tags          String[]        // Stocké comme tableau de strings
  impact        String?         @db.VarChar(200)
  technologies  String[]        // Stocké comme tableau de strings
  team          String?         @db.VarChar(100)
  duration      String?         @db.VarChar(50)
  budget        String?         @db.VarChar(50)
  status        ReferenceStatus @default(PUBLISHED)
  publishedAt   DateTime?
  authorId      String?         @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([country])
  @@index([category])
  @@index([date])
  @@index([client])
  @@index([status])
  @@index([slug])
  @@map("references")
}

enum ReferenceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}