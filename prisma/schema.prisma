generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique @db.VarChar(255)
  username      String?    @unique @db.VarChar(100)
  passwordHash  String
  firstName     String?    @db.VarChar(100)
  lastName      String?    @db.VarChar(100)
  phone         String?    @db.VarChar(30)
  avatarUrl     String?
  status        UserStatus @default(PENDING)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  createdAudits AuditLog[]  @relation("AuditActor")
  authTokens    AuthToken[]
  pages         Page[]
  posts         Post[]
  products      Product[]
  projects      Project[]
  sessions      Session[]
  assignedRoles UserRole[]  @relation("UserRoleAssignedBy")
  userRoles     UserRole[]

  // Email Marketing
  contactGroups ContactGroup[]
  contacts      Contact[]
  campaigns     Campaign[]

  // CRM
  crmCompanies     CrmCompany[]
  crmOffers        CrmOffer[]
  crmOpportunities CrmOpportunity[]
  crmTenders       CrmTender[]
  crmTasks         CrmTask[]
  crmActivities    CrmActivity[]

  @@index([email])
  @@index([username])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  code            String           @unique @db.VarChar(100)
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
  @@index([code])
  @@index([isSystem])
  @@map("roles")
}

model PermissionResource {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  code            String           @unique @db.VarChar(100)
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([name])
  @@index([code])
  @@index([isActive])
  @@map("permission_resources")
}

model RolePermission {
  id                String            @id @default(uuid()) @db.Uuid
  roleId            String            @db.Uuid
  resourceId        String            @db.Uuid
  canRead           Boolean           @default(false)
  canCreate         Boolean           @default(false)
  canUpdate         Boolean           @default(false)
  canDelete         Boolean           @default(false)
  canList           Boolean           @default(false)
  canExport         Boolean           @default(false)
  canApprove        Boolean           @default(false)
  canManage         Boolean           @default(false)
  specialPermission SpecialPermission @default(NONE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  resource PermissionResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role     Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceId])
  @@index([roleId])
  @@index([resourceId])
  @@index([specialPermission])
  @@map("role_permissions")
}

model UserRole {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  roleId       String   @db.Uuid
  assignedById String?  @db.Uuid
  assignedAt   DateTime @default(now())

  assignedBy User? @relation("UserRoleAssignedBy", fields: [assignedById], references: [id])
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  token        String    @unique
  refreshToken String?   @unique
  ipAddress    String?   @db.VarChar(64)
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @db.VarChar(100)
  metadata  Json?
  ipAddress String?  @db.VarChar(64)
  userAgent String?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Page {
  id            String     @id @default(uuid()) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  description   String?
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  status        PageStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String     @db.Uuid
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@map("pages")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts Post[]

  @@index([slug])
  @@map("categories")
}

model Post {
  id            String     @id @default(uuid()) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  excerpt       String?
  coverImage    String?
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String     @db.Uuid
  categoryId    String?    @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?      @db.JsonB
  gjsHtml       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  gjsJs         String?

  tags     PostTag[]
  author   User      @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
  @@map("posts")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  posts PostTag[]

  @@index([slug])
  @@map("tags")
}

model PostTag {
  postId String @db.Uuid
  tagId  String @db.Uuid

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Project {
  id            String        @id @default(uuid()) @db.Uuid
  title         String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  excerpt       String?
  coverImage    String?
  images        String[]
  techStack     String[]
  projectUrl    String?
  githubUrl     String?
  status        ProjectStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String        @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("projects")
}

model ProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@map("product_categories")
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  excerpt       String?
  price         Decimal?      @db.Decimal(10, 2)
  coverImage    String?
  images        String[]
  status        ProductStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String        @db.Uuid
  categoryId    String?       @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author   User             @relation(fields: [authorId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id])

  crmOffers        CrmOffer[]
  crmOpportunities CrmOpportunity[]

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@map("products")
}

model ContactMessage {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(255)
  phone     String?       @db.VarChar(30)
  subject   String?       @db.VarChar(255)
  message   String
  status    ContactStatus @default(NEW)
  ipAddress String?       @db.VarChar(64)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

model Reference {
  id            String          @id @default(uuid()) @db.Uuid
  country       String          @db.VarChar(100)
  code          String          @db.VarChar(10)
  lat           Decimal         @db.Decimal(10, 6)
  lng           Decimal         @db.Decimal(10, 6)
  title         String          @db.VarChar(500)
  slug          String          @unique @db.VarChar(500)
  excerpt       String          @db.Text
  image         String          @db.VarChar(500)
  details       String          @db.Text
  date          String          @db.VarChar(10)
  client        String          @db.VarChar(200)
  category      String          @db.VarChar(100)
  tags          String[]
  impact        String?         @db.VarChar(200)
  technologies  String[]
  team          String?         @db.VarChar(100)
  duration      String?         @db.VarChar(50)
  budget        String?         @db.VarChar(50)
  status        ReferenceStatus @default(PUBLISHED)
  publishedAt   DateTime?
  authorId      String?         @db.Uuid
  gjsComponents Json?
  gjsStyles     Json?
  gjsHtml       String?
  gjsJs         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([country])
  @@index([category])
  @@index([date])
  @@index([client])
  @@index([status])
  @@index([slug])
  @@map("references")
}

// ============================================================
// EMAIL MARKETING
// ============================================================

model ContactGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts       Contact[]
  members        ContactGroupMember[]
  campaigns      Campaign[]
  campaignGroups CampaignGroup[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
  @@map("contact_groups")
}

model ContactGroupMember {
  id        String   @id @default(cuid())
  contactId String
  groupId   String
  createdAt DateTime @default(now())

  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group   ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([contactId, groupId])
  @@index([contactId])
  @@index([groupId])
  @@map("contact_group_members")
}

model Contact {
  id           String   @id @default(cuid())
  email        String
  firstName    String?
  lastName     String?
  phone        String?
  metadata     Json?
  isActive     Boolean  @default(true)
  unsubscribed Boolean  @default(false)
  groupId      String?
  userId       String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // CRM
  jobTitle      String?
  companyName   String?
  country       String?
  city          String?
  notes         String?          @db.Text
  crmStatus     CrmContactStatus @default(NEW)
  crmSource     CrmLeadSource    @default(MANUAL)
  consentDate   DateTime?
  consentSource String?

  crmCompanyId String?
  crmCompany   CrmCompany? @relation(fields: [crmCompanyId], references: [id], onDelete: SetNull)

  crmOpportunities CrmOpportunity[]
  crmTasks         CrmTask[]
  crmActivities    CrmActivity[]

  group            ContactGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupMemberships ContactGroupMember[]
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients       CampaignRecipient[]

  @@unique([email, userId])
  @@index([userId])
  @@index([groupId])
  @@index([crmCompanyId])
  @@index([crmStatus])
  @@index([crmSource])
  @@map("contacts")
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  subject         String
  htmlContent     String         @db.Text
  fromName        String         @default("Mon App")
  fromEmail       String
  replyTo         String?
  groupId         String?
  status          CampaignStatus @default(DRAFT)
  userId          String         @db.Uuid
  sentAt          DateTime?
  scheduledAt     DateTime?
  totalRecipients Int            @default(0)
  sentCount       Int            @default(0)
  failedCount     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  group          ContactGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients     CampaignRecipient[]
  logs           EmailLog[]
  campaignGroups CampaignGroup[]

  @@index([userId])
  @@index([status])
  @@index([groupId])
  @@map("campaigns")
}

model CampaignGroup {
  id         String   @id @default(cuid())
  campaignId String
  groupId    String
  createdAt  DateTime @default(now())

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  group    ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([campaignId, groupId])
  @@index([campaignId])
  @@index([groupId])
  @@map("campaign_groups")
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  contactId  String
  email      String
  sent       Boolean   @default(false)
  delivered  Boolean   @default(false)
  openedAt   DateTime?
  clickedAt  DateTime?
  error      String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@map("campaign_recipients")
}

model EmailLog {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  status     String
  message    String?
  provider   String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("email_logs")
}

// ============================================================
// CRM MULTI-PRODUITS — MD2I
// ============================================================

model CrmCompany {
  id        String         @id @default(cuid())
  name      String
  type      CrmCompanyType @default(COMPANY)
  sector    String?
  website   String?
  email     String?
  phone     String?
  country   String?
  city      String?
  address   String?
  notes     String?        @db.Text

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contacts      Contact[]
  opportunities CrmOpportunity[]
  tenders       CrmTender[]
  tasks         CrmTask[]
  activities    CrmActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([name])
  @@index([type])
  @@index([country])
  @@map("crm_companies")
}

model CrmOffer {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  status      CrmOfferStatus @default(DRAFT)

  normalPrice Decimal? @db.Decimal(12, 2)
  promoPrice  Decimal? @db.Decimal(12, 2)
  currency    String?  @default("EUR") @db.VarChar(10)

  startsAt DateTime?
  endsAt   DateTime?

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunities CrmOpportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@map("crm_offers")
}

model CrmOpportunity {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text

  amount      Decimal? @db.Decimal(12, 2)
  currency    String?  @default("EUR") @db.VarChar(10)
  probability Int      @default(0)

  stage  CrmOpportunityStage @default(NEW)
  source CrmLeadSource       @default(MANUAL)

  requestType    CrmRequestType @default(CONTACT)
  nextFollowUpAt DateTime?
  lostReason     String?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  offerId String?
  offer   CrmOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  tenderId String?
  tender   CrmTender? @relation(fields: [tenderId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks      CrmTask[]
  activities CrmActivity[]

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  landingPage String?
  referrer    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([productId])
  @@index([offerId])
  @@index([tenderId])
  @@index([stage])
  @@index([source])
  @@index([requestType])
  @@index([createdAt])
  @@index([nextFollowUpAt])
  @@map("crm_opportunities")
}

model CrmTender {
  id          String  @id @default(cuid())
  title       String
  reference   String?
  buyerName   String?
  country     String?
  sourceUrl   String?
  description String? @db.Text
  notes       String? @db.Text

  status CrmTenderStatus @default(IDENTIFIED)

  publishedAt     DateTime?
  deadline        DateTime?
  estimatedAmount Decimal? @db.Decimal(12, 2)
  currency        String?  @default("EUR") @db.VarChar(10)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunities CrmOpportunity[]
  tasks         CrmTask[]
  activities    CrmActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([deadline])
  @@index([country])
  @@map("crm_tenders")
}

model CrmTask {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text

  status   CrmTaskStatus   @default(TODO)
  priority CrmTaskPriority @default(MEDIUM)

  dueDate     DateTime?
  completedAt DateTime?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  tenderId String?
  tender   CrmTender? @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([tenderId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("crm_tasks")
}

model CrmActivity {
  id          String          @id @default(cuid())
  type        CrmActivityType
  title       String
  description String?         @db.Text
  metadata    Json?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  tenderId String?
  tender   CrmTender? @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([tenderId])
  @@index([type])
  @@index([createdAt])
  @@map("crm_activities")
}

// ============================================================
// ENUMS EXISTANTS
// ============================================================

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  REFRESH_TOKEN
}

enum SpecialPermission {
  NONE
  FULL_ACCESS
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum ReferenceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
  SCHEDULED
}

// ============================================================
// ENUMS CRM
// ============================================================

enum CrmContactStatus {
  NEW
  PROSPECT
  HOT_PROSPECT
  CUSTOMER
  PARTNER
  INACTIVE
  LOST
}

enum CrmLeadSource {
  WEBSITE
  FACEBOOK
  LINKEDIN
  EMAIL_CAMPAIGN
  GOOGLE
  DIRECT
  TENDER
  REFERRAL
  MANUAL
  OTHER
}

enum CrmCompanyType {
  COMPANY
  NGO
  PROJECT
  ADMINISTRATION
